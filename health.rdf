     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:healthcare_group17="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17"/>
    


    <!-- 
