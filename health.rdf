            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment>Drug causes side effect</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#hasSymptom -->

