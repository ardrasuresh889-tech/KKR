    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#takesMedication -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#takesMedication">
