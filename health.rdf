    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Symptom -->

    <owl:Class rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Symptom">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </owl:equivalentClass>
    </owl:Class>
    


