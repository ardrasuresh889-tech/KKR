    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#contraindicatedWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#contraindicatedWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Drug"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Drug"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment>Drug conflicts with another drug</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#diagnoseWith -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#diagnoseWith">
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Patient"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#Disease"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#rational"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:comment>Patient diagnosed with disease</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#hasSideEffect -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/cecompany/ontologies/2025/11/healthcare_group17#hasSideEffect">
